generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth (NextAuth) ----------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  ADMIN
  EDITOR
  ANALYST
  VIEWER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(VIEWER)
  title         String?

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  accounts      Account[]
  sessions      Session[]
  notifications Notification[]
  apiKeys       ApiKey[]
  reports       Report[]
  dashboards    Dashboard[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------- Organization ----------

model Organization {
  id       String @id @default(cuid())
  name     String
  slug     String @unique
  plan     String @default("Enterprise")
  logoUrl  String?

  users      User[]
  dashboards Dashboard[]
  reports    Report[]
  customers  Customer[]
  apiKeys    ApiKey[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------- Dashboards & Reports ----------

model Dashboard {
  id             String   @id @default(cuid())
  name           String
  description    String?
  isDefault      Boolean  @default(false)
  layout         Json?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownerId        String
  owner          User     @relation(fields: [ownerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ReportCadence {
  DAILY
  WEEKLY
  MONTHLY
}

enum ReportFormat {
  CSV
  PDF
}

model Report {
  id             String        @id @default(cuid())
  name           String
  description    String?
  cadence        ReportCadence @default(WEEKLY)
  format         ReportFormat  @default(PDF)
  recipients     String[]
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownerId        String
  owner          User          @relation(fields: [ownerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------- Metrics / System health ----------

enum MetricName {
  CPU
  MEMORY
  LATENCY_P50
  LATENCY_P95
  LATENCY_P99
  ERROR_RATE
  REQUESTS_PER_MIN
  AVAILABILITY
}

model Metric {
  id        String     @id @default(cuid())
  name      MetricName
  service   String
  value     Float
  timestamp DateTime   @default(now())

  @@index([name, service, timestamp])
}

enum ServiceStatus {
  OPERATIONAL
  DEGRADED
  PARTIAL_OUTAGE
  MAJOR_OUTAGE
}

model Service {
  id           String        @id @default(cuid())
  name         String        @unique
  status       ServiceStatus @default(OPERATIONAL)
  uptime90d    Float         @default(99.99)
  region       String
  updatedAt    DateTime      @updatedAt
}

enum DeploymentStatus {
  SUCCESS
  FAILED
  IN_PROGRESS
  ROLLED_BACK
}

model Deployment {
  id          String           @id @default(cuid())
  service     String
  version     String
  status      DeploymentStatus
  author      String
  commitSha   String
  durationSec Int
  createdAt   DateTime         @default(now())
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

model LogEntry {
  id        String   @id @default(cuid())
  level     LogLevel
  service   String
  message   String
  metadata  Json?
  timestamp DateTime @default(now())

  @@index([level, timestamp])
}

// ---------- Product events / activity ----------

enum EventType {
  SIGNUP
  LOGIN
  UPGRADE
  DOWNGRADE
  CHURN
  PAYMENT
  API_CALL
  ERROR
  FEATURE_USE
}

model Event {
  id         String    @id @default(cuid())
  type       EventType
  actor      String
  actorEmail String?
  message    String
  metadata   Json?
  timestamp  DateTime  @default(now())

  @@index([type, timestamp])
}

// ---------- Traffic ----------

model TrafficDaily {
  id              String   @id @default(cuid())
  date            DateTime @unique
  sessions        Int
  pageviews       Int
  visitors        Int
  conversionRate  Float

  @@index([date])
}

// ---------- Revenue ----------

model Revenue {
  id         String   @id @default(cuid())
  date       DateTime
  amount     Float
  mrr        Float
  newMrr     Float
  churnedMrr Float
  plan       String
  region     String

  @@index([date])
}

// ---------- Customers ----------

enum CustomerStatus {
  ACTIVE
  TRIAL
  PAST_DUE
  CHURNED
}

enum CustomerSegment {
  ENTERPRISE
  MID_MARKET
  SMB
  STARTUP
}

model Customer {
  id             String          @id @default(cuid())
  name           String
  company        String
  email          String
  avatarSeed     String
  plan           String
  mrr            Float
  ltv            Float
  status         CustomerStatus  @default(ACTIVE)
  segment        CustomerSegment @default(SMB)
  country        String
  healthScore    Int             @default(80)
  sessionsCount  Int             @default(0)
  lastActiveAt   DateTime        @default(now())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  deals Deal[]

  createdAt DateTime @default(now())
}

// ---------- Sales Pipeline ----------

enum DealStage {
  LEAD
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

model Deal {
  id          String    @id @default(cuid())
  name        String
  amount      Float
  stage       DealStage @default(LEAD)
  probability Int       @default(20)
  closeDate   DateTime
  owner       String
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------- Notifications ----------

enum NotificationLevel {
  INFO
  SUCCESS
  WARNING
  ERROR
}

model Notification {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  level     NotificationLevel @default(INFO)
  title     String
  body      String
  read      Boolean           @default(false)
  createdAt DateTime          @default(now())
}

// ---------- API Keys ----------

model ApiKey {
  id             String       @id @default(cuid())
  name           String
  keyPrefix      String
  keyHash        String
  scopes         String[]
  lastUsedAt     DateTime?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User         @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  revokedAt DateTime?
}
