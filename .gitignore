# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
# .env is committed on purpose — it holds only a non-secret placeholder
# DATABASE_URL so `prisma generate` has a value to resolve during install/build
# even before a real database is configured (see DEPLOYMENT.md). Real secrets
# go in .env.local (git-ignored) or your hosting provider's env var settings,
# both of which take precedence over .env.
.env.local
.env.*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
