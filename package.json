    "lucide-react": "^1.23.0",
    "next": "15.5.20",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.80.0",
    "react-virtuoso": "^4.18.10",
    "recharts": "^3.9.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
