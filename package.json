{
  "name": "pulse-analytics-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "dotenv -c -- prisma db push",
    "db:migrate": "dotenv -c -- prisma migrate dev",
    "db:seed": "dotenv -c -- tsx prisma/seed.ts",
    "db:studio": "dotenv -c -- prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
