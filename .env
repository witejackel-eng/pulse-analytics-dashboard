# Non-secret placeholder so `prisma generate`/`prisma validate` always have a
# DATABASE_URL to resolve during `npm install` (see postinstall) and `next build`,
# even before a real database is provisioned. This is never used to actually
# connect — server/queries/*.ts fall back to curated data on any connection
# error — and it is overridden by .env.local locally or by real environment
# variables configured in your hosting provider (e.g. Vercel).
DATABASE_URL="postgresql://user:password@localhost:5432/postgres?schema=public"
