# --- Auth (required) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# --- Database (optional in development) ---
# The app gracefully falls back to curated demo data when this is unreachable
# or unset, so you can run `npm run dev` without a live Postgres instance.
DATABASE_URL="postgresql://user:password@localhost:5432/pulse_analytics"

# --- Google OAuth (optional) ---
# Leave blank to disable the "Continue with Google" button's real auth;
# credentials sign-in with the seeded demo accounts always works.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
